# API Configuration
# The backend API URL (should end with /api)
# For production: https://updownlive.com/api
# For local development: http://localhost:5000/api
NEXT_PUBLIC_API_URL=https://updownlive.com/api

# Backend URL (without /api suffix) - Optional, will be derived from NEXT_PUBLIC_API_URL if not set
# BACKEND_URL=https://updownlive.com

